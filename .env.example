# Ollama配置
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# 实例管理平台配置
INSTANCE_PLATFORM_URL=http://your-platform-api.example.com
INSTANCE_PLATFORM_TOKEN=your-api-token

# Django Configuration
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (MySQL) - Django ORM
DB_NAME=rds_agent
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# MySQL默认连接配置（可选，用于测试诊断）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mysql

# Redis Configuration (Celery Broker)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery Configuration
CELERY_WORKER_CONCURRENCY=5
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# 监控平台配置（可选）
MONITOR_API_URL=http://your-monitor-api.example.com

# 向量知识库配置
VECTOR_STORE_PATH=./data/vector_store
CHROMA_COLLECTION_NAME=rds_knowledge

# Agent配置
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/rds_agent.log
DJANGO_LOG_LEVEL=INFO